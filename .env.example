NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SUB

# SQLite for local dev; swap to a hosted Postgres URL (e.g. Neon/Supabase) on Vercel.
DATABASE_URL=file:./dev.db

# Stripe — leave as placeholder to run in demo mode.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Printify — leave as placeholder to run in demo mode.
PRINTIFY_API_TOKEN=placeholder
PRINTIFY_SHOP_ID=placeholder
PRINTIFY_BLUEPRINT_ID=placeholder
PRINTIFY_PRINT_PROVIDER_ID=placeholder

RESEND_API_KEY=placeholder
BLOB_READ_WRITE_TOKEN=placeholder

# Site-wide HTTP Basic Auth (set both on Vercel to enable).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
